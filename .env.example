# Variables de entorno para ERP B2B Premium
# Copia este archivo como .env y completa los valores

# Supabase (obligatorio)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase (server-side, obligatorio para Server Actions)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (solo server-side, NUNCA exponer al cliente)
# Úsalo solo cuando sea estrictamente necesario; prefiere anon key + RLS
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Tenant por defecto (opcional, default: "acme")
NEXT_PUBLIC_DEFAULT_TENANT_CODE=acme
