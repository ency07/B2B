# =============================================================================
# ERP B2B Premium — Variables de Entorno
# =============================================================================
# Copia este archivo al entorno deseado:
#   cp .env.example .env.local        # Desarrollo local
#   cp .env.example .env.staging      # Staging
#   cp .env.example .env.production   # Producción
#
# Next.js carga archivos .env en este orden (lo último prevalece):
#   1. .env
#   2. .env.local        (ignorado por git, ideal para desarrollo local)
#   3. .env.development  (solo en `next dev`)
#   4. .env.production   (solo en `next start` / build)
#
# Convención del proyecto:
#   - Dev local:   .env.local
#   - Staging:     .env.staging  (cargado con: dotenv -e .env.staging -- next dev)
#   - Producción:  .env.production
# =============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# SUPABASE — Variables públicas (exponer al cliente)
# ──────────────────────────────────────────────────────────────────────────────
# Se obtienen del proyecto en https://supabase.com/dashboard

# URL del proyecto (ej: https://abc123.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon key pública (segura para el cliente gracias a RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Tenant por defecto (dev: "acme", staging/prod según corresponda)
NEXT_PUBLIC_DEFAULT_TENANT_CODE=acme

# ──────────────────────────────────────────────────────────────────────────────
# SUPABASE — Variables de servidor (NUNCA exponer al cliente)
# ──────────────────────────────────────────────────────────────────────────────
# Las variables sin prefijo NEXT_PUBLIC_ solo existen en Node y Server Components

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key — SOLO para migraciones, seeds y operaciones que requieran
# bypass de RLS. NUNCA la uses en Server Actions que procesen datos de usuario;
# prefiere anon key + RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ──────────────────────────────────────────────────────────────────────────────
# CONFIGURACIÓN DEL PROYECTO
# ──────────────────────────────────────────────────────────────────────────────
# Suprimir warnings de tenant no encontrado (útil en tests/CI)
# Valores: "true" | "false" (por defecto se muestran en dev, se suprimen en prod)
# SUPPRESS_TENANT_WARNINGS=false

# ──────────────────────────────────────────────────────────────────────────────
# EJEMPLO: Variables específicas por entorno
# ──────────────────────────────────────────────────────────────────────────────
# .env.local (desarrollo):
#   NEXT_PUBLIC_SUPABASE_URL=https://localhost:54321   # Supabase local
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...local-anon-key
#   SUPABASE_SERVICE_ROLE_KEY=eyJ...local-service-role
#   NEXT_PUBLIC_DEFAULT_TENANT_CODE=acme
#
# .env.staging:
#   NEXT_PUBLIC_SUPABASE_URL=https://staging-project.supabase.co
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...staging-anon-key
#   SUPABASE_SERVICE_ROLE_KEY=eyJ...staging-service-role
#   NEXT_PUBLIC_DEFAULT_TENANT_CODE=acme
#
# .env.production:
#   NEXT_PUBLIC_SUPABASE_URL=https://prod-project.supabase.co
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...prod-anon-key
#   SUPABASE_SERVICE_ROLE_KEY=eyJ...prod-service-role
#   NEXT_PUBLIC_DEFAULT_TENANT_CODE=acme
